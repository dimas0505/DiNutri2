# Arquivo: .env.example
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env — ele está no .gitignore.

# 1. URL do Banco de Dados (PostgreSQL da Neon)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# 2. Segredo da Sessão (string aleatória longa)
SESSION_SECRET="sua-chave-secreta-de-sessao-aqui"

# 3. Credenciais do Auth0
AUTH0_DOMAIN="seu-dominio.us.auth0.com"
AUTH0_CLIENT_ID="seu-client-id"
AUTH0_CLIENT_SECRET="seu-client-secret"

# 4. URL Base da Aplicação
BASE_URL="https://sua-url-de-deploy.com"

# 5. Token do Vercel Blob Storage
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# 6. Credenciais do Admin
#ADMIN_EMAIL="seu-email@admin.com"
ADMIN_PASSWORD="sua-senha-admin"
ADMIN_FIRST_NAME="Admin"
ADMIN_LAST_NAME="Principal"

# 7. Notificações Push (Web Push API - VAPID)
# Para gerar novas chaves VAPID:
#   node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(k);"
VAPID_PUBLIC_KEY="BGKKOirr7QB_WGX4VPj87pYfwe5HNZtGXS8jtTmhR-QgGTCeTh0t_VDXG7BrhYQW-QgRVHb8ML5IxS2_SVN7X2E"
VAPID_PRIVATE_KEY="zMl4iQipDDjcCdF-BK1qglna675kx4IfTuYJEZ_WpAo"
VAPID_EMAIL="mailto:seu-email@dominio.com"
